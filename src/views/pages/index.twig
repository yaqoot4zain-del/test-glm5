{% extends 'layouts/master.twig' %}

{% block content %}
{# Hero Section - Full Width Banner #}
<section class="hero">
    <div class="hero__slider" id="hero-slider">
        {% if theme.settings.get('hero_slides') %}
            {% for slide in theme.settings.get('hero_slides') %}
            <div class="hero__slide">
                <div class="hero__image-wrapper">
                    <img src="{{ slide.image }}" alt="{{ slide.title }}" class="hero__image">
                </div>
                <div class="hero__overlay"></div>
                <div class="hero__content container">
                    {% if slide.subtitle %}
                    <p class="hero__subtitle">{{ slide.subtitle }}</p>
                    {% endif %}
                    <h1 class="hero__title">{{ slide.title }}</h1>
                    {% if slide.text %}
                    <p class="hero__text">{{ slide.text }}</p>
                    {% endif %}
                    {% if slide.button_url %}
                    <a href="{{ slide.button_url }}" class="btn btn--gold btn--large hero__btn">
                        {{ slide.button_text ?? 'SHOP NOW' }}
                    </a>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        {% else %}
        {# Default Hero #}
        <div class="hero__slide">
            <div class="hero__image-wrapper">
                <img src="{{ 'images/hero-default.jpg' | asset }}" alt="{{ store.name }}" class="hero__image">
            </div>
            <div class="hero__overlay"></div>
            <div class="hero__content container">
                <p class="hero__subtitle">New Collection</p>
                <h1 class="hero__title">{{ 'Elegant Jewelry' | trans }}</h1>
                <p class="hero__text">{{ 'Discover our exquisite collection of fine jewelry' | trans }}</p>
                <a href="{{ store.products_url }}" class="btn btn--gold btn--large hero__btn">
                    SHOP NOW
                </a>
            </div>
        </div>
        {% endif %}
    </div>
</section>

{# Collections Navigation #}
<section class="collections-nav">
    <div class="container">
        <nav class="collections-nav__inner">
            <a href="{{ store.products_url }}" class="collections-nav__link">{{ 'All' | trans }}</a>
            <a href="/collections/rings" class="collections-nav__link">{{ 'Rings' | trans }}</a>
            <a href="/collections/earrings" class="collections-nav__link">{{ 'Earrings' | trans }}</a>
            <a href="/collections/bracelets" class="collections-nav__link">{{ 'Bracelets' | trans }}</a>
            <a href="/collections/necklaces" class="collections-nav__link">{{ 'Necklaces' | trans }}</a>
        </nav>
    </div>
</section>

{# Featured Products - Bestsellers #}
{% component 'component-featured-products' with {
    'section_title': 'Bestsellers',
    'section_id': 'bestsellers',
    'limit': 4,
    'source': 'bestseller'
} %}

{# Banner CTA #}
<section class="banner-cta">
    <div class="container">
        <div class="banner-cta__inner">
            <div class="banner-cta__content">
                <h2 class="banner-cta__title">{{ 'Shop Our Collection' | trans }}</h2>
                <p class="banner-cta__text">{{ 'Discover timeless pieces crafted with precision' | trans }}</p>
                <a href="{{ store.products_url }}" class="btn btn--outline">{{ 'View All' | trans }}</a>
            </div>
        </div>
    </div>
</section>

{# New Arrivals #}
{% component 'component-featured-products' with {
    'section_title': 'New Arrivals',
    'section_id': 'new-arrivals',
    'limit': 4,
    'source': 'new'
} %}

{# Category Sections #}
<section class="category-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">{{ 'Necklaces' | trans }}</h2>
            <a href="/collections/necklaces" class="section-link">{{ 'View all' | trans }}</a>
        </div>
        <div class="products-grid">
            {% component 'component-products-slider' with {'collection': 'necklaces', 'limit': 4} %}
        </div>
    </div>
</section>

<section class="category-section category-section--alt">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">{{ 'Rings' | trans }}</h2>
            <a href="/collections/rings" class="section-link">{{ 'View all' | trans }}</a>
        </div>
        <div class="products-grid">
            {% component 'component-products-slider' with {'collection': 'rings', 'limit': 4} %}
        </div>
    </div>
</section>

<section class="category-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">{{ 'Earrings' | trans }}</h2>
            <a href="/collections/earrings" class="section-link">{{ 'View all' | trans }}</a>
        </div>
        <div class="products-grid">
            {% component 'component-products-slider' with {'collection': 'earrings', 'limit': 4} %}
        </div>
    </div>
</section>

<section class="category-section category-section--alt">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">{{ 'Bracelets' | trans }}</h2>
            <a href="/collections/bracelets" class="section-link">{{ 'View all' | trans }}</a>
        </div>
        <div class="products-grid">
            {% component 'component-products-slider' with {'collection': 'bracelets', 'limit': 4} %}
        </div>
    </div>
</section>

{# Brand Story Section #}
<section class="brand-story">
    <div class="container">
        <div class="brand-story__inner">
            <div class="brand-story__image">
                <img src="{{ theme.settings.get('brand_image') ?? ('images/brand-story.jpg' | asset) }}" alt="{{ 'Our Story' | trans }}">
            </div>
            <div class="brand-story__content">
                <h2 class="brand-story__title">{{ 'Our Story' | trans }}</h2>
                <p class="brand-story__text">{{ theme.settings.get('brand_story') ?? 'At LuluOro, we believe that jewelry should be as unique as the person wearing it. Each piece is crafted with precision and passion, combining traditional artistry with contemporary design.' | trans }}</p>
                <a href="/pages/about" class="btn btn--gold">{{ 'Learn More' | trans }}</a>
            </div>
        </div>
    </div>
</section>

{# Instagram Feed #}
{% if theme.settings.get('show_instagram_feed') %}
<section class="instagram-feed">
    <div class="container">
        <h2 class="section-title section-title--center">{{ 'Follow Us on Instagram' | trans }}</h2>
        <div class="instagram-grid" id="instagram-grid">
            {% for image in theme.settings.get('instagram_images') %}
            <a href="{{ image.url ?? '#' }}" class="instagram-item" target="_blank">
                <img src="{{ image.image }}" alt="Instagram" class="instagram-item__img">
                <div class="instagram-item__overlay">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# Shop the Looks #}
{% if theme.settings.get('shop_the_looks') %}
<section class="shop-looks">
    <div class="container">
        <h2 class="section-title section-title--center">{{ 'Shop the Looks' | trans }}</h2>
        <div class="looks-grid">
            {% for look in theme.settings.get('shop_the_looks') %}
            <a href="{{ look.url }}" class="look-item">
                <img src="{{ look.image }}" alt="{{ look.title }}" class="look-item__img">
                <h3 class="look-item__title">{{ look.title }}</h3>
            </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{{ content_for('home') }}
{% endblock %}