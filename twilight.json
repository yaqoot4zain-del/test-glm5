{
    "name": {
        "ar": "لولو أورو",
        "en": "LuluOro"
    },
    "repository": "https://github.com/yaqoot4zain-del/test-glm5",
    "author_email": "yaqoot4zain@gmail.com",
    "support_url": "https://salla.dev",
    "description": {
        "ar": "ثيم أنيق للمجوهرات مع تصميم عصري وميزات متقدمة",
        "en": "Elegant jewelry theme with modern design and advanced features"
    },
    "features": [
        "component-featured-products",
        "component-fixed-banner",
        "component-fixed-products",
        "component-photos-slider",
        "component-products-slider",
        "component-parallax-background",
        "component-random-testimonials",
        "component-testimonials",
        "component-square-photos",
        "component-store-features",
        "component-youtube",
        "filters"
    ],
    "settings": [
        {
            "type": "boolean",
            "label": {
                "ar": "شريط علوي داكن",
                "en": "Dark Top Bar"
            },
            "id": "topnav_is_dark",
            "format": "switch",
            "selected": false
        },
        {
            "type": "string",
            "id": "placeholder",
            "format": "hidden",
            "value": "images/img_placeholder.png"
        },
        {
            "type": "string",
            "id": "primary_color",
            "label": {
                "ar": "اللون الأساسي",
                "en": "Primary Color"
            },
            "format": "color",
            "value": "#B8860B"
        },
        {
            "type": "string",
            "id": "secondary_color",
            "label": {
                "ar": "اللون الثانوي",
                "en": "Secondary Color"
            },
            "format": "color",
            "value": "#1a1a1a"
        },
        {
            "type": "string",
            "id": "accent_color",
            "label": {
                "ar": "لون التمييز",
                "en": "Accent Color"
            },
            "format": "color",
            "value": "#D4AF37"
        },
        {
            "type": "string",
            "id": "logo",
            "label": {
                "ar": "الشعار",
                "en": "Logo"
            },
            "format": "image",
            "value": ""
        },
        {
            "type": "boolean",
            "id": "show_announcement_bar",
            "label": {
                "ar": "إظهار شريط الإعلانات",
                "en": "Show Announcement Bar"
            },
            "format": "switch",
            "selected": true
        },
        {
            "type": "string",
            "id": "announcement_text",
            "label": {
                "ar": "نص الإعلان",
                "en": "Announcement Text"
            },
            "format": "text",
            "value": "Join the Insiders Club"
        },
        {
            "type": "string",
            "id": "footer_about_text",
            "label": {
                "ar": "نص حول المتجر في الفوتر",
                "en": "Store About Text in Footer"
            },
            "format": "textarea",
            "value": "Discover exquisite jewelry crafted with precision and passion."
        },
        {
            "type": "boolean",
            "id": "newsletter_enabled",
            "label": {
                "ar": "تفعيل النشرة البريدية",
                "en": "Enable Newsletter"
            },
            "format": "switch",
            "selected": true
        }
    ],
    "components": [
        {
            "key": "hero-banner",
            "title": {
                "ar": "بانر رئيسي",
                "en": "Hero Banner"
            },
            "icon": "sicon-banner",
            "path": "home.hero-banner",
            "fields": [
                {
                    "id": "slides",
                    "type": "collection",
                    "format": "collection",
                    "required": true,
                    "minLength": 1,
                    "maxLength": 5,
                    "fields": [
                        {
                            "id": "slides.image",
                            "type": "string",
                            "format": "image",
                            "label": {
                                "ar": "الصورة",
                                "en": "Image"
                            },
                            "required": true
                        },
                        {
                            "id": "slides.title",
                            "type": "string",
                            "label": {
                                "ar": "العنوان",
                                "en": "Title"
                            }
                        },
                        {
                            "id": "slides.subtitle",
                            "type": "string",
                            "label": {
                                "ar": "العنوان الفرعي",
                                "en": "Subtitle"
                            }
                        },
                        {
                            "id": "slides.button_text",
                            "type": "string",
                            "label": {
                                "ar": "نص الزر",
                                "en": "Button Text"
                            }
                        },
                        {
                            "id": "slides.button_url",
                            "type": "items",
                            "format": "variable-list",
                            "label": {
                                "ar": "رابط الزر",
                                "en": "Button URL"
                            }
                        }
                    ]
                }
            ]
        },
        {
            "key": "collections-grid",
            "title": {
                "ar": "شبكة المجموعات",
                "en": "Collections Grid"
            },
            "icon": "sicon-grid",
            "path": "home.collections-grid",
            "fields": [
                {
                    "id": "section_title",
                    "type": "string",
                    "label": {
                        "ar": "عنوان القسم",
                        "en": "Section Title"
                    }
                },
                {
                    "id": "collections",
                    "type": "collection",
                    "format": "collection",
                    "required": true,
                    "minLength": 2,
                    "maxLength": 6,
                    "fields": [
                        {
                            "id": "collections.image",
                            "type": "string",
                            "format": "image",
                            "label": {
                                "ar": "صورة المجموعة",
                                "en": "Collection Image"
                            }
                        },
                        {
                            "id": "collections.title",
                            "type": "string",
                            "label": {
                                "ar": "اسم المجموعة",
                                "en": "Collection Name"
                            }
                        },
                        {
                            "id": "collections.url",
                            "type": "items",
                            "format": "variable-list",
                            "label": {
                                "ar": "رابط المجموعة",
                                "en": "Collection URL"
                            }
                        }
                    ]
                }
            ]
        },
        {
            "key": "products-carousel",
            "title": {
                "ar": "عرض المنتجات",
                "en": "Products Carousel"
            },
            "icon": "sicon-products-slider",
            "path": "home.products-carousel",
            "fields": [
                {
                    "id": "section_title",
                    "type": "string",
                    "label": {
                        "ar": "عنوان القسم",
                        "en": "Section Title"
                    }
                },
                {
                    "id": "products_type",
                    "type": "items",
                    "format": "dropdown-list",
                    "label": {
                        "ar": "نوع المنتجات",
                        "en": "Products Type"
                    },
                    "options": [
                        {
                            "label": {
                                "ar": "الأكثر مبيعاً",
                                "en": "Best Sellers"
                            },
                            "value": "bestseller"
                        },
                        {
                            "label": {
                                "ar": "جديد",
                                "en": "New Arrivals"
                            },
                            "value": "new"
                        },
                        {
                            "label": {
                                "ar": "مميز",
                                "en": "Featured"
                            },
                            "value": "featured"
                        }
                    ]
                },
                {
                    "id": "products_count",
                    "type": "string",
                    "format": "number",
                    "label": {
                        "ar": "عدد المنتجات",
                        "en": "Products Count"
                    },
                    "value": "8"
                }
            ]
        },
        {
            "key": "brand-story",
            "title": {
                "ar": "قصة العلامة التجارية",
                "en": "Brand Story"
            },
            "icon": "sicon-text",
            "path": "home.brand-story",
            "fields": [
                {
                    "id": "title",
                    "type": "string",
                    "label": {
                        "ar": "العنوان",
                        "en": "Title"
                    }
                },
                {
                    "id": "content",
                    "type": "string",
                    "format": "textarea",
                    "label": {
                        "ar": "المحتوى",
                        "en": "Content"
                    }
                },
                {
                    "id": "image",
                    "type": "string",
                    "format": "image",
                    "label": {
                        "ar": "الصورة",
                        "en": "Image"
                    }
                },
                {
                    "id": "button_text",
                    "type": "string",
                    "label": {
                        "ar": "نص الزر",
                        "en": "Button Text"
                    }
                },
                {
                    "id": "button_url",
                    "type": "items",
                    "format": "variable-list",
                    "label": {
                        "ar": "رابط الزر",
                        "en": "Button URL"
                    }
                }
            ]
        },
        {
            "key": "instagram-feed",
            "title": {
                "ar": "تغذية انستغرام",
                "en": "Instagram Feed"
            },
            "icon": "sicon-instagram",
            "path": "home.instagram-feed",
            "fields": [
                {
                    "id": "section_title",
                    "type": "string",
                    "label": {
                        "ar": "عنوان القسم",
                        "en": "Section Title"
                    }
                },
                {
                    "id": "images",
                    "type": "collection",
                    "format": "collection",
                    "minLength": 4,
                    "maxLength": 8,
                    "fields": [
                        {
                            "id": "images.image",
                            "type": "string",
                            "format": "image",
                            "label": {
                                "ar": "الصورة",
                                "en": "Image"
                            }
                        },
                        {
                            "id": "images.url",
                            "type": "items",
                            "format": "variable-list",
                            "label": {
                                "ar": "الرابط",
                                "en": "URL"
                            }
                        }
                    ]
                }
            ]
        }
    ]
}