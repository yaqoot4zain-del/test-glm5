{
    "name": {
        "ar": "لولو أورو",
        "en": "LuluOro"
    },
    "repository": "https://github.com/yaqoot4zain-del/test-glm5",
    "author_email": "yaqoot4zain@gmail.com",
    "support_url": "https://salla.dev",
    "description": {
        "ar": "ثيم مجوهرات أنيق مستوحى من luluoro.com",
        "en": "Elegant jewelry theme inspired by luluoro.com"
    },
    "features": [
        "mega-menu",
        "fonts",
        "color",
        "breadcrumb",
        "unite-cards-height",
        "component-featured-products",
        "component-fixed-banner",
        "component-fixed-products",
        "component-products-slider",
        "component-photos-slider",
        "component-parallax-background",
        "component-testimonials",
        "component-square-photos",
        "component-store-features",
        "component-youtube",
        "menu-images",
        "filters"
    ],
    "settings": [
        {
            "type": "boolean",
            "label": {
                "ar": "إظهار شريط الإعلانات",
                "en": "Show Announcement Bar"
            },
            "id": "show_announcement_bar",
            "format": "switch",
            "selected": true
        },
        {
            "type": "string",
            "id": "announcement_text",
            "label": {
                "ar": "نص الإعلان",
                "en": "Announcement Text"
            },
            "format": "text",
            "value": "Free Shipping on Orders Over 500 SAR"
        },
        {
            "type": "string",
            "id": "logo",
            "label": {
                "ar": "الشعار",
                "en": "Logo"
            },
            "format": "image",
            "value": ""
        },
        {
            "type": "string",
            "id": "primary_color",
            "label": {
                "ar": "اللون الأساسي",
                "en": "Primary Color"
            },
            "format": "color",
            "value": "#B8860B"
        },
        {
            "type": "string",
            "id": "secondary_color",
            "label": {
                "ar": "اللون الثانوي",
                "en": "Secondary Color"
            },
            "format": "color",
            "value": "#1a1a1a"
        },
        {
            "type": "string",
            "id": "accent_color",
            "label": {
                "ar": "لون التمييز",
                "en": "Accent Color"
            },
            "format": "color",
            "value": "#D4AF37"
        },
        {
            "type": "boolean",
            "id": "newsletter_enabled",
            "label": {
                "ar": "تفعيل النشرة البريدية",
                "en": "Enable Newsletter"
            },
            "format": "switch",
            "selected": true
        },
        {
            "type": "string",
            "id": "footer_about_text",
            "label": {
                "ar": "نص حول المتجر",
                "en": "Store About Text"
            },
            "format": "textarea",
            "value": "Discover exquisite jewelry crafted with precision and passion."
        }
    ],
    "components": [
        {
            "key": "hero-banner",
            "title": {
                "ar": "بانر رئيسي",
                "en": "Hero Banner"
            },
            "icon": "sicon-banner",
            "path": "home.hero-banner",
            "fields": [
                {
                    "id": "hero_slides",
                    "type": "collection",
                    "format": "collection",
                    "required": true,
                    "minLength": 1,
                    "maxLength": 5,
                    "label": {
                        "ar": "شرائح البانر",
                        "en": "Hero Slides"
                    },
                    "fields": [
                        {
                            "id": "hero_slides.image",
                            "type": "string",
                            "format": "image",
                            "label": {
                                "ar": "الصورة",
                                "en": "Image"
                            },
                            "required": true
                        },
                        {
                            "id": "hero_slides.title",
                            "type": "string",
                            "label": {
                                "ar": "العنوان",
                                "en": "Title"
                            }
                        },
                        {
                            "id": "hero_slides.subtitle",
                            "type": "string",
                            "label": {
                                "ar": "العنوان الفرعي",
                                "en": "Subtitle"
                            }
                        },
                        {
                            "id": "hero_slides.text",
                            "type": "string",
                            "format": "textarea",
                            "label": {
                                "ar": "النص",
                                "en": "Text"
                            }
                        },
                        {
                            "id": "hero_slides.button_text",
                            "type": "string",
                            "label": {
                                "ar": "نص الزر",
                                "en": "Button Text"
                            },
                            "value": "SHOP NOW"
                        },
                        {
                            "id": "hero_slides.button_url",
                            "type": "items",
                            "format": "variable-list",
                            "label": {
                                "ar": "رابط الزر",
                                "en": "Button URL"
                            }
                        }
                    ]
                }
            ]
        },
        {
            "key": "featured-products",
            "title": {
                "ar": "منتجات مميزة",
                "en": "Featured Products"
            },
            "icon": "sicon-products-slider",
            "path": "home.featured-products",
            "fields": [
                {
                    "id": "section_title",
                    "type": "string",
                    "label": {
                        "ar": "عنوان القسم",
                        "en": "Section Title"
                    },
                    "value": "Bestsellers"
                },
                {
                    "id": "limit",
                    "type": "string",
                    "format": "number",
                    "label": {
                        "ar": "عدد المنتجات",
                        "en": "Products Count"
                    },
                    "value": "4"
                }
            ]
        },
        {
            "key": "brand-story",
            "title": {
                "ar": "قصة العلامة التجارية",
                "en": "Brand Story"
            },
            "icon": "sicon-text",
            "path": "home.brand-story",
            "fields": [
                {
                    "id": "brand_image",
                    "type": "string",
                    "format": "image",
                    "label": {
                        "ar": "صورة القصة",
                        "en": "Story Image"
                    }
                },
                {
                    "id": "brand_story",
                    "type": "string",
                    "format": "textarea",
                    "label": {
                        "ar": "نص القصة",
                        "en": "Story Text"
                    },
                    "value": "At LuluOro, we believe that jewelry should be as unique as the person wearing it. Each piece is crafted with precision and passion, combining traditional artistry with contemporary design."
                }
            ]
        },
        {
            "key": "instagram-feed",
            "title": {
                "ar": "تغذية انستغرام",
                "en": "Instagram Feed"
            },
            "icon": "sicon-instagram",
            "path": "home.instagram-feed",
            "fields": [
                {
                    "id": "show_instagram_feed",
                    "type": "boolean",
                    "format": "switch",
                    "label": {
                        "ar": "إظهار تغذية انستغرام",
                        "en": "Show Instagram Feed"
                    },
                    "selected": true
                },
                {
                    "id": "instagram_images",
                    "type": "collection",
                    "format": "collection",
                    "minLength": 4,
                    "maxLength": 6,
                    "label": {
                        "ar": "صور انستغرام",
                        "en": "Instagram Images"
                    },
                    "fields": [
                        {
                            "id": "instagram_images.image",
                            "type": "string",
                            "format": "image",
                            "label": {
                                "ar": "الصورة",
                                "en": "Image"
                            }
                        },
                        {
                            "id": "instagram_images.url",
                            "type": "string",
                            "format": "url",
                            "label": {
                                "ar": "الرابط",
                                "en": "URL"
                            }
                        }
                    ]
                }
            ]
        },
        {
            "key": "shop-the-looks",
            "title": {
                "ar": "تسوق الإطلالات",
                "en": "Shop the Looks"
            },
            "icon": "sicon-layout-grid",
            "path": "home.shop-looks",
            "fields": [
                {
                    "id": "shop_the_looks",
                    "type": "collection",
                    "format": "collection",
                    "minLength": 2,
                    "maxLength": 6,
                    "label": {
                        "ar": "الإطلالات",
                        "en": "Looks"
                    },
                    "fields": [
                        {
                            "id": "shop_the_looks.image",
                            "type": "string",
                            "format": "image",
                            "label": {
                                "ar": "الصورة",
                                "en": "Image"
                            }
                        },
                        {
                            "id": "shop_the_looks.title",
                            "type": "string",
                            "label": {
                                "ar": "العنوان",
                                "en": "Title"
                            }
                        },
                        {
                            "id": "shop_the_looks.url",
                            "type": "items",
                            "format": "variable-list",
                            "label": {
                                "ar": "الرابط",
                                "en": "URL"
                            }
                        }
                    ]
                }
            ]
        }
    ]
}